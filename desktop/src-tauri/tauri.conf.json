{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MeTerm",
  "version": "0.2.2",
  "identifier": "com.meterm.app",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5175"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0"
    },
    "windows": {
      "wix": {
        "language": ["en-US", "zh-CN"]
      },
      "nsis": {
        "languages": ["English", "SimpChinese"]
      }
    }
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "MeTerm",
        "width": 1000,
        "height": 700,
        "resizable": true,
        "decorations": true,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 14,
          "y": 18
        },
        "hiddenTitle": true,
        "acceptFirstMouse": true,
        "visible": false,
        "backgroundColor": [45, 45, 45, 255]
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; connect-src * ipc://localhost http://ipc.localhost http://tauri.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost http://asset.localhost data:; frame-src 'none'; object-src 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$RESOURCE/**", "$APPDATA/backgrounds/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU3QUQwRTBBQTI0RkQ5QkMKUldTODJVK2lDZzZ0NTBUbjJKdDZVZklKWXQ4Y0p1NmJyWDBQeXlPN2JaaklYUEtJNlQ1SGlwL0sK",
      "endpoints": [
        "https://meterm-updater.bruceli1059705314.workers.dev/meterm/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": false,
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}
